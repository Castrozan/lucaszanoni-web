{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@/core": ["./src/modules/core/index.ts"],
      "@/core/*": ["./src/modules/core/*"],
      "@/canvas": ["./src/modules/canvas/index.ts"],
      "@/canvas/*": ["./src/modules/canvas/*"],
      "@/sandbox": ["./src/modules/sandbox/index.ts"],
      "@/sandbox/*": ["./src/modules/sandbox/*"],
      "@/generation": ["./src/modules/generation/index.ts"],
      "@/generation/*": ["./src/modules/generation/*"],
      "@/catalog": ["./src/modules/catalog/index.ts"],
      "@/catalog/*": ["./src/modules/catalog/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", "next-env.d.ts", ".next/types/**/*.ts"],
  "exclude": ["node_modules", "vitest.config.ts"]
}
