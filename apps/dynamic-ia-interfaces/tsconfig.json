{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@/core/*": [
        "./src/modules/core/*"
      ],
      "@/intent/*": [
        "./src/modules/intent/*"
      ],
      "@/specification/*": [
        "./src/modules/specification/*"
      ],
      "@/conversation/*": [
        "./src/modules/conversation/*"
      ],
      "@/agent/*": [
        "./src/modules/agent/*"
      ],
      "@/multimodal/*": [
        "./src/modules/multimodal/*"
      ],
      "@/composition/*": [
        "./src/modules/composition/*"
      ],
      "@/adaptive/*": [
        "./src/modules/adaptive/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "next-env.d.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "vitest.config.ts"
  ]
}
