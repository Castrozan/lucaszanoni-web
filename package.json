{
  "name": "atrium",
  "private": true,
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "dev": "turbo run dev",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md,yaml,yml}\""
  },
  "devDependencies": {
    "@turbo/gen": "^2.5.8",
    "prettier": "^3.4.2",
    "turbo": "^2.5.8",
    "typescript": "^5.7.3"
  }
}
