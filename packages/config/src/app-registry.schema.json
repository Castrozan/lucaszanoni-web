{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://lucaszanoni.com/schemas/app-registry.schema.json",
  "title": "Platform application registry",
  "description": "The single declarative source of truth every consumer derives from: typed loader, Terraform, and the deploy matrix.",
  "type": "array",
  "items": { "$ref": "#/definitions/appRegistryEntry" },
  "definitions": {
    "appRegistryEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "mountPath",
        "navigationLabel",
        "description",
        "showInCrossSectionNavigation",
        "status",
        "accessModel",
        "origin"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "mountPath": { "type": "string", "pattern": "^(/|/.*/)$" },
        "navigationLabel": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "showInCrossSectionNavigation": { "type": "boolean" },
        "status": { "enum": ["active", "retired"] },
        "accessModel": { "$ref": "#/definitions/accessModel" },
        "accessApplicationProvisioning": {
          "$ref": "#/definitions/accessApplicationProvisioning"
        },
        "origin": { "$ref": "#/definitions/origin" },
        "servingLocation": { "$ref": "#/definitions/servingLocation" },
        "healthProbePath": { "type": "string", "pattern": "^/" }
      },
      "allOf": [
        {
          "if": {
            "required": ["origin"],
            "properties": {
              "origin": {
                "required": ["kind"],
                "properties": {
                  "kind": { "const": "static-gcs-bucket" }
                }
              }
            }
          },
          "then": {
            "properties": {
              "accessModel": {
                "required": ["kind"],
                "properties": {
                  "kind": { "const": "public" }
                }
              }
            }
          }
        }
      ]
    },
    "servingLocation": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind"],
          "properties": { "kind": { "const": "path-prefix" } }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "subdomainLabel"],
          "properties": {
            "kind": { "const": "subdomain" },
            "subdomainLabel": {
              "type": "string",
              "pattern": "^[a-z0-9]([a-z0-9-]{0,61}[a-z0-9])?$"
            }
          }
        }
      ]
    },
    "accessApplicationProvisioning": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind"],
          "properties": { "kind": { "const": "dedicated" } }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "parentMountPath"],
          "properties": {
            "kind": { "const": "inherited-from-parent-path" },
            "parentMountPath": { "type": "string", "pattern": "^/.*/$" }
          }
        }
      ]
    },
    "accessModel": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind"],
          "properties": { "kind": { "const": "public" } }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind"],
          "properties": { "kind": { "const": "owner-only" } }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "audienceKey"],
          "properties": {
            "kind": { "const": "shared" },
            "audienceKey": { "type": "string", "minLength": 1 }
          }
        }
      ]
    },
    "origin": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "cloudRunServiceName",
            "appPackageName",
            "appDirectoryName",
            "buildProfile",
            "nonSecretEnvironment",
            "secretEnvironmentReferences"
          ],
          "properties": {
            "kind": { "const": "in-repo-cloud-run" },
            "cloudRunServiceName": { "type": "string", "minLength": 1 },
            "appPackageName": { "type": "string", "minLength": 1 },
            "appDirectoryName": { "type": "string", "minLength": 1 },
            "buildProfile": { "enum": ["static-spa", "dynamic-service"] },
            "nonSecretEnvironment": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            },
            "secretEnvironmentReferences": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "originHost",
            "pathRewrite",
            "forwardedBasePath",
            "trusted"
          ],
          "properties": {
            "kind": { "const": "external-https" },
            "originHost": { "type": "string", "minLength": 1 },
            "pathRewrite": { "enum": ["preserve", "strip-mount-path"] },
            "forwardedBasePath": { "type": "string" },
            "trusted": { "type": "boolean" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "bucketName", "objectKeyPrefix"],
          "properties": {
            "kind": { "const": "static-gcs-bucket" },
            "bucketName": { "type": "string", "minLength": 1 },
            "objectKeyPrefix": { "type": "string" }
          }
        }
      ]
    }
  }
}
